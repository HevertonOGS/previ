generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Reference data
// ─────────────────────────────────────────────

model ExpenseType {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())

  generalExpenses  GeneralExpense[]
  currentExpenses  CurrentExpense[]
  weeklyTypeItems  WeeklyBalanceByTypeItem[]
}

enum CategoryKind {
  INCOME
  EXPENSE
  BOTH
}

model Category {
  id        String       @id @default(uuid())
  name      String       @unique
  kind      CategoryKind @default(EXPENSE)
  createdAt DateTime     @default(now())

  generalExpenses     GeneralExpense[]
  currentExpenses     CurrentExpense[]
  weeklyCategoryItems WeeklyBalanceByCategoryItem[]
}

// Customizable status options for incomes
model IncomeStatusOption {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// Customizable status options for expenses
model ExpenseStatusOption {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// Customizable payment method options
model PaymentMethodOption {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// Shared source options for incomes and expenses
model SourceOption {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// Monthly periods
// ─────────────────────────────────────────────

model Period {
  id        String   @id @default(uuid())
  year      Int
  month     Int      // 1–12
  createdAt DateTime @default(now())

  incomes         Income[]
  generalExpenses GeneralExpense[]
  currentExpenses CurrentExpense[]
  weeklyBalances  WeeklyBalance[]

  @@unique([year, month])
}

// ─────────────────────────────────────────────
// Incomes
// ─────────────────────────────────────────────

model Income {
  id                String   @id @default(uuid())
  periodId          String
  name              String
  category          String
  source            String?
  expectedAmount    Decimal  @db.Decimal(12, 2)
  actualAmount      Decimal? @db.Decimal(12, 2)
  expectedReceiptAt DateTime?
  receivedAt        DateTime?
  status            String   @default("Pendente")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  period Period @relation(fields: [periodId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// General expenses (predictable, planned before or during the month)
// ─────────────────────────────────────────────

model GeneralExpense {
  id              String   @id @default(uuid())
  periodId        String
  expenseTypeId   String
  categoryId      String
  name            String
  source          String?
  estimatedAmount Decimal  @db.Decimal(12, 2)
  actualAmount    Decimal? @db.Decimal(12, 2)
  expectedPayAt   DateTime?
  paidAt          DateTime?
  status          String   @default("Estimado")
  paymentMethod   String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  period      Period      @relation(fields: [periodId], references: [id], onDelete: Cascade)
  expenseType ExpenseType @relation(fields: [expenseTypeId], references: [id])
  category    Category    @relation(fields: [categoryId], references: [id])
}

// ─────────────────────────────────────────────
// Current expenses (occur during the month: groceries, delivery, transport, etc.)
// ─────────────────────────────────────────────

model CurrentExpense {
  id            String   @id @default(uuid())
  periodId      String
  expenseTypeId String
  categoryId    String
  name          String
  source        String?
  amount        Decimal  @db.Decimal(12, 2)
  paidAt        DateTime
  paymentMethod String
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  period      Period      @relation(fields: [periodId], references: [id], onDelete: Cascade)
  expenseType ExpenseType @relation(fields: [expenseTypeId], references: [id])
  category    Category    @relation(fields: [categoryId], references: [id])
}

// ─────────────────────────────────────────────
// Weekly balances
// ─────────────────────────────────────────────

model WeeklyBalance {
  id         String   @id @default(uuid())
  periodId   String
  weekNumber Int      // week within the month (1–5)
  startDate  DateTime
  endDate    DateTime
  budget     Decimal  @db.Decimal(12, 2)
  totalSpent Decimal  @default(0) @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  period          Period                        @relation(fields: [periodId], references: [id], onDelete: Cascade)
  byTypeItems     WeeklyBalanceByTypeItem[]
  byCategoryItems WeeklyBalanceByCategoryItem[]

  @@unique([periodId, weekNumber])
}

model WeeklyBalanceByTypeItem {
  id              String  @id @default(uuid())
  weeklyBalanceId String
  expenseTypeId   String
  amount          Decimal @default(0) @db.Decimal(12, 2)

  weeklyBalance WeeklyBalance @relation(fields: [weeklyBalanceId], references: [id], onDelete: Cascade)
  expenseType   ExpenseType   @relation(fields: [expenseTypeId], references: [id])

  @@unique([weeklyBalanceId, expenseTypeId])
}

model WeeklyBalanceByCategoryItem {
  id              String  @id @default(uuid())
  weeklyBalanceId String
  categoryId      String
  amount          Decimal @default(0) @db.Decimal(12, 2)

  weeklyBalance WeeklyBalance @relation(fields: [weeklyBalanceId], references: [id], onDelete: Cascade)
  category      Category      @relation(fields: [categoryId], references: [id])

  @@unique([weeklyBalanceId, categoryId])
}

// ─────────────────────────────────────────────
// Savings goals
// ─────────────────────────────────────────────

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model Goal {
  id           String     @id @default(uuid())
  name         String
  targetAmount Decimal    @db.Decimal(12, 2)
  targetDate   DateTime?
  status       GoalStatus @default(ACTIVE)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  entries GoalEntry[]
}

model GoalEntry {
  id            String   @id @default(uuid())
  goalId        String
  year          Int
  month         Int
  plannedAmount Decimal  @db.Decimal(12, 2)
  actualAmount  Decimal? @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id])

  @@unique([goalId, year, month])
}
